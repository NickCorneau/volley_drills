  "entrypoint_contracts": [
    {
      "path": "AGENTS.md",
      "purpose": "Canonical prose repo contract for cold-start routing, source-of-truth order, current state, and operating constraints.",
      "use_when": [
        "starting any session",
        "resolving source-of-truth conflicts",
        "checking repo-wide agent rules or vocabularies"
      ],
      "not_for": [
        "replacing product canon",
        "serving as the exhaustive machine index",
        "storing raw research detail"
      ],
      "update_when": [
        "cold-start protocol changes",
        "source-of-truth hierarchy changes",
        "current phase, milestone, or blocking-gate change",
        "repo-wide agent operating constraints change"
      ],
      "machine_companions": ["docs/catalog.json", "agent-manifest.json", "llms.txt"]
    },
    {
      "path": "docs/README.md",
      "purpose": "Prose editorial index for the docs system and update routing.",
      "use_when": [
        "routing a docs update",
        "deciding which doc owns a concept",
        "checking editorial hierarchy"
      ],
      "not_for": [
        "exhaustive machine-only routing",
        "overriding product canon"
      ],
      "update_when": [
        "doc inventory changes materially",
        "doc ownership changes",
        "agent fast-path read order changes",
        "agent entry surfaces or docs-editing routes change"
      ],
      "machine_companions": ["docs/catalog.json", "docs/ops/agent-documentation-contract.md"]
    },
    {
      "path": "docs/research/README.md",
      "purpose": "Prose router for the curated research notes.",
      "use_when": [
        "choosing the narrowest research note",
        "deciding whether a finding belongs in canon or research"
      ],
      "not_for": [
        "replacing canon",
        "mining raw provenance when curated notes already exist"
      ],
      "update_when": [
        "a new curated research note is added",
        "research note routing changes"
      ],
      "machine_companions": ["docs/catalog.json"]
    },
    {
      "path": "docs/ops/agent-runtime.md",
      "purpose": "Canonical prose runtime contract for bounded agent work.",
      "use_when": [
        "working on runtime or control-plane files",
        "checking task lifecycle, worktree policy, or worker roles"
      ],
      "not_for": [
        "replacing product canon",
        "acting as the formal task schema"
      ],
      "update_when": [
        "runtime stack changes",
        "task lifecycle or worktree policy changes",
        "control-plane layout changes"
      ],
      "machine_companions": ["docs/catalog.json", "ops/agent/queue/task-template.json", "ops/agent/schemas/task.schema.json"]
    },
    {
      "path": "docs/ops/agent-documentation-contract.md",
      "purpose": "Canonical prose contract for agent entry surfaces, machine-scannable docs, and change propagation.",
      "use_when": [
        "editing docs",
        "changing agent entry surfaces",
        "changing durable doc conventions"
      ],
      "not_for": [
        "replacing product canon",
        "acting as the exhaustive machine index"
      ],
      "update_when": [
        "entry surfaces change",
        "machine-scannable doc conventions change",
        "change-propagation rules change"
      ],
      "machine_companions": ["docs/catalog.json", "AGENTS.md", "agent-manifest.json", "llms.txt"]
    },
    {
      "path": "ops/agent/README.md",
      "purpose": "Prose companion for the repo-local task queue, handoffs, schemas, and worker flow.",
      "use_when": [
        "working under ops/agent",
        "checking task states, handoffs, or script entrypoints"
      ],
      "not_for": [
        "product direction",
        "replacing the formal task schema or enum files"
      ],
      "update_when": [
        "queue layout changes",
        "task-state vocabulary changes",
        "script entrypoints change"
      ],
      "machine_companions": ["ops/agent/queue/task-template.json", "ops/agent/schemas/task.schema.json", "ops/agent/schemas/status-enums.json"]
